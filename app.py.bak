<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script>
// Theme Switcher Logic
function switchMainTheme(themeName) {
    document.body.className = '';
    document.body.classList.add('theme-' + themeName);
    toast("UI Theme adapted: " + themeName.toUpperCase());
}

// BGM Music Player Logic
const audio=document.getElementById('bgAudio');let playing=false;const mDisc=document.getElementById('mDisc'),mEq=document.getElementById('mEq'),mIcon=document.getElementById('mIcon'),mLbl=document.getElementById('mLbl'),mTitle=document.getElementById('mTitle');
function setMusic(on){playing=on;mDisc.classList.toggle('paused',!on);mEq.classList.toggle('paused',!on);mIcon.className=on?'fas fa-pause':'fas fa-play';mLbl.textContent=on?'PAUSE':'PLAY';mTitle.textContent=on?'♪ Now Playing — BGM':'♪ Music Paused';}
document.getElementById('mBtn').onclick=()=>{if(playing){audio.pause();setMusic(false);}else audio.play().then(()=>setMusic(true)).catch(()=>{});};
let autoTried=false;['click','touchstart'].forEach(ev=>document.addEventListener(ev,()=>{if(!autoTried&&!playing){autoTried=true;audio.play().then(()=>setMusic(true)).catch(()=>{});}},{once:true}));

function toast(msg){const t=document.createElement('div');t.className='toast';t.innerHTML='<i class="fas fa-info-circle"></i> &nbsp; '+msg;document.body.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity .4s';setTimeout(()=>t.remove(),400);},3000);}

// Live Dynamic Bangladesh (BD) Time Clock & Date
function updateBDTime() {
    const d = new Date();
    // Sycing UTC+6 (Bangladesh Time)
    const utc = d.getTime() + (d.getTimezoneOffset() * 60000);
    const bdDate = new Date(utc + (3600000 * 6));
    
    // Time Format
    let hrs = bdDate.getHours();
    let mins = bdDate.getMinutes();
    let secs = bdDate.getSeconds();
    let ampm = hrs >= 12 ? 'PM' : 'AM';
    hrs = hrs % 12;
    hrs = hrs ? hrs : 12; // 0 should be 12
    const timeStr = (hrs < 10 ? '0' : '') + hrs + ':' + (mins < 10 ? '0' : '') + mins + ':' + (secs < 10 ? '0' : '') + secs + ' ' + ampm;
    document.getElementById('telemetry-time').innerText = timeStr;
    
    // Date Format
    const day = bdDate.getDate();
    const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
    const month = months[bdDate.getMonth()];
    const year = bdDate.getFullYear();
    document.getElementById('telemetry-date').innerText = day + " " + month + " " + year;
}

// Dynamic Device & Browser Detection
function detectDevice() {
    const ua = navigator.userAgent;
    let device = "Computer";
    if (/android/i.test(ua)) {
        device = "Android Phone";
    } else if (/iPhone|iPad|iPod/i.test(ua)) {
        device = "iOS Device";
    }
    
    // Browser parser
    let browser = "Browser";
    if (ua.indexOf("Chrome") > -1) browser = "Chrome";
    else if (ua.indexOf("Firefox") > -1) browser = "Firefox";
    else if (ua.indexOf("Safari") > -1) browser = "Safari";
    else if (ua.indexOf("Opera") > -1 || ua.indexOf("OPR") > -1) browser = "Opera";
    
    document.getElementById('telemetry-device').innerText = device + " (" + browser + ")";
}

// Live HTML5 Battery Telemetry API
function monitorBatteryCharge() {
    if (navigator.getBattery) {
        navigator.getBattery().then(function(battery) {
            function updateBatteryInfo() {
                const charge = Math.round(battery.level * 100);
                document.getElementById('telemetry-battery').innerText = charge + "%" + (battery.charging ? " (⚡)" : "");
                
                // Update icon based on state
                const batIco = document.getElementById('battery-ico');
                if (battery.charging) {
                    batIco.innerHTML = '<i class="fas fa-charging-station" style="color:var(--success)"></i>';
                } else if (charge <= 20) {
                    batIco.innerHTML = '<i class="fas fa-battery-empty" style="color:var(--err)"></i>';
                } else if (charge <= 60) {
                    batIco.innerHTML = '<i class="fas fa-battery-quarter" style="color:var(--dim)"></i>';
                } else {
                    batIco.innerHTML = '<i class="fas fa-battery-full" style="color:var(--success)"></i>';
                }
            }
            updateBatteryInfo();
            battery.addEventListener('levelchange', updateBatteryInfo);
            battery.addEventListener('chargingchange', updateBatteryInfo);
        });
    } else {
        document.getElementById('telemetry-battery').innerText = "Not Supported";
    }
}

// Interactive Color-Shifting Falling Petals (Dynamic Custom Accent-matching)
const canvas = document.getElementById('galaxy-canvas');
const ctx = canvas.getContext('2d');
let petalsArray = [];

window.addEventListener('resize', () => {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
});

class Petal {
  constructor() {
    this.x = Math.random() * canvas.width;
    this.y = Math.random() * canvas.height - canvas.height;
    this.size = Math.random() * 8 + 6;
    this.speed = Math.random() * 1.5 + 1;
    this.angle = Math.random() * 360;
    this.spin = Math.random() * 1 - 0.5;
    this.wind = Math.random() * 0.5 - 0.25;
  }
  draw() {
    const activeColor = getComputedStyle(document.body).getPropertyValue('--p').trim();
    ctx.save();
    ctx.translate(this.x, this.y);
    ctx.rotate(this.angle * Math.PI / 180);
    ctx.beginPath();
    
    // Procedural glowing flower petal curves
    ctx.moveTo(0, 0);
    ctx.bezierCurveTo(-this.size/2, -this.size/2, -this.size, this.size/3, 0, this.size);
    ctx.bezierCurveTo(this.size, this.size/3, this.size/2, -this.size/2, 0, 0);
    
    ctx.fillStyle = activeColor.replace(')', ', 0.35)').replace('rgb', 'rgba').replace('#', 'rgba');
    ctx.shadowBlur = 10;
    ctx.shadowColor = activeColor;
    ctx.fill();
    ctx.restore();
  }
  update() {
    this.y += this.speed;
    this.x += this.wind;
    this.angle += this.spin;
    
    // Recycle petals when falling offscreen
    if (this.y > canvas.height + 20) {
      this.y = -20;
      this.x = Math.random() * canvas.width;
      this.speed = Math.random() * 1.5 + 1;
    }
    this.draw();
  }
}

function init() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
  petalsArray = [];
  const petalCount = 45; // Smooth performance threshold
  for (let i = 0; i < petalCount; i++) {
    petalsArray.push(new Petal());
  }
}

function animate() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  
  // Luxury Deep Background Mesh Radial Gradient
  let grad = ctx.createRadialGradient(canvas.width/2, canvas.height/2, 0, canvas.width/2, canvas.height/2, canvas.width);
  grad.addColorStop(0, '#090422');
  grad.addColorStop(1, '#010006');
  ctx.fillStyle = grad;
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  
  for (let i = 0; i < petalsArray.length; i++) {
    petalsArray[i].update();
  }
  requestAnimationFrame(animate);
}

document.addEventListener('DOMContentLoaded', () => {
    init();
    animate();
    detectDevice();
    monitorBatteryCharge();
    setInterval(updateBDTime, 1000);
    toast("Welcome to Aʏᴀɴ Gᴀʟʟᴇʀʏ Portal.");
});
</script>
</body>
</html>
"""

@app.route('/')
def index():
    visit_count = get_and_increment_visits()
    return render_template_string(HTML_TEMPLATE, visit_count=visit_count)

if __name__ == '__main__':
    port = int(os.environ.get("PORT", 8080))
    app.run(host='0.0.0.0', port=port, debug=False)