#!/usr/bin/env python3
import os
from flask import Flask, render_template_string

app = Flask(__name__)

VISIT_FILE = "visits.txt"

def get_and_increment_visits():
    # এস্তাবলিশড বেস কাউন্ট হিসেবে ১০৪২ থেকে শুরু হবে
    count = 1042  
    try:
        if os.path.exists(VISIT_FILE):
            with open(VISIT_FILE, "r") as f:
                count = int(f.read().strip())
        count += 1
        with open(VISIT_FILE, "w") as f:
            f.write(str(count))
    except Exception:
        pass
    return count

