  color: var(--txt);
}

/* App Showcase Card Styles */
.card{background:var(--card);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid var(--brd);border-radius:1.6rem;padding:2rem;position:relative;overflow:hidden;transition:all .3s;box-shadow:0 8px 40px rgba(0,0,0,.7),inset 0 1px 0 rgba(0,255,231,.06);margin-bottom:1.8rem}
.card::before{content:"";position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--p),var(--g1),var(--acc),var(--p),transparent);opacity:.55}
.card:hover{border-color:rgba(0,255,231,.45);box-shadow:0 15px 40px var(--glow)}

.app-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:2rem}
.app-card{background:var(--card);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid var(--brd);border-radius:1.6rem;padding:2rem;position:relative;overflow:hidden;transition:all 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);box-shadow:0 8px 40px rgba(0,0,0,.7),inset 0 1px 0 rgba(0,255,231,.06);display:flex;flex-direction:column;justify-content:space-between}
.app-card::before{content:"";position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--p),var(--g1),var(--p),transparent);opacity:.55}
.app-card:hover{border-color:rgba(0,255,231,.42);transform:translateY(-8px);box-shadow:0 15px 40px var(--glow)}

.app-header{display:flex;align-items:center;gap:1.2rem;margin-bottom:1.5rem}
.app-icon{width:64px;height:64px;border-radius:1.1rem;flex-shrink:0;background:linear-gradient(135deg,rgba(0,255,231,.12),rgba(255,110,199,.1));border:1px solid rgba(0,255,231,.25);display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:var(--p);transition: color 0.5s, border-color 0.5s;}
.app-details{flex:1}
.app-title{font-family:'Orbitron',sans-serif;font-size:1.1rem;font-weight:700;color:var(--txt);letter-spacing:1.5px;text-transform:uppercase}

.app-desc{font-size:.85rem;color:#bbfef7;line-height:1.6;margin-bottom:1.5rem;flex:1}
.app-features{list-style:none;margin-bottom:1.8rem;display:flex;flex-direction:column;gap:.5rem}
.app-features li{font-size:.78rem;color:var(--dim);display:flex;align-items:center;gap:.5rem}
.app-features li i{color:var(--p);font-size:.8rem;transition: color 0.5s;}

.app-btn{width:100%;padding:.85rem;border-radius:.75rem;border:none;cursor:pointer;font-family:'Orbitron',sans-serif;font-size:.75rem;letter-spacing:1.5px;text-transform:uppercase;display:inline-flex;align-items:center;justify-content:center;gap:.6rem;font-weight:700;text-decoration:none;transition:all .25s}
.app-btn-live{background:linear-gradient(135deg,#006655,var(--p2));color:var(--dark);box-shadow:0 4px 20px rgba(0,255,231,.35)}
.app-btn-live:hover{background:linear-gradient(135deg,var(--p),var(--p3));box-shadow:0 6px 28px var(--glow);transform:translateY(-2px)}

/* Coming Soon Style Card */
.coming-soon{border-color:rgba(255,110,199,.15);background:rgba(15, 8, 42, 0.45)}
.coming-soon::before{background:linear-gradient(90deg,transparent,var(--g1),transparent);opacity:.35}
.coming-soon .app-icon{color:var(--g1);background:linear-gradient(135deg,rgba(255,110,199,.08),rgba(192,38,211,.05));border-color:rgba(255,110,199,.2)}
.coming-soon .app-features li i{color:var(--g1)}
.app-btn-soon{background:rgba(255,110,199,.05);border:1px solid rgba(255,110,199,.2);color:var(--g1);cursor:not-allowed}

.divider{border:none;border-top:1px solid rgba(0,255,231,.08);margin:3.5rem 0 2rem}
.foot{text-align:center;color:var(--dim);font-size:.76rem;letter-spacing:1.5px;font-family:'Orbitron',sans-serif;padding:.5rem}
.foot span{background:linear-gradient(90deg,var(--p),var(--g1));-webkit-background-clip:text;-webkit-text-fill-color:transparent}

/* Toast Message */
.toast{position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;background:rgba(3,13,11,.96);border-radius:.8rem;padding:.85rem 1.2rem;font-family:'Orbitron',sans-serif;font-size:.7rem;letter-spacing:1px;display:flex;align-items:center;gap:.7rem;max-width:320px;box-shadow:0 8px 30px rgba(0,0,0,.6);animation:toastIn .3s ease;border:1px solid rgba(0,255,231,.15);border-left:3px solid var(--p);color:var(--p)}
@keyframes toastIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:translateX(0)}}
</style>
